@page "/accounts"
@using BankingApp.Web.Services
@using BankingApp.Web.Models
@inject AccountService AccountService

<PageTitle>Accounts</PageTitle>

<h3>Bank Accounts</h3>

@if (isLoading)
{
    <p><em>Loading accounts...</em></p>
}
else if (errorMessage != null)
{
    <div class="alert alert-danger">
        <strong>Error:</strong> @errorMessage
    </div>
}
else if (accounts != null && accounts.Any())
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Account Number</th>
                <th>Account Holder</th>
                <th>Balance</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var account in accounts)
            {
                <tr>
                    <td>@account.AccountNumber</td>
                    <td>@account.AccountHolderName</td>
                    <td>@account.Balance.ToString("C")</td>
                    <td>
                        <a href="/accounts/@account.Id" class="btn btn-sm btn-primary">Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (response != null)
    {
        <div class="mt-3">
            <nav>
                <ul class="pagination">
                    <li class="page-item @(response.PageNumber == 1 ? "disabled" : "")">
                        <button class="page-link" @onclick="() => LoadPage(response.PageNumber - 1)" disabled="@(response.PageNumber == 1)">Previous</button>
                    </li>
                    
                    @for (int i = 1; i <= response.TotalPages; i++)
                    {
                        var pageNum = i;
                        <li class="page-item @(pageNum == response.PageNumber ? "active" : "")">
                            <button class="page-link" @onclick="() => LoadPage(pageNum)">@pageNum</button>
                        </li>
                    }
                    
                    <li class="page-item @(response.PageNumber == response.TotalPages ? "disabled" : "")">
                        <button class="page-link" @onclick="() => LoadPage(response.PageNumber + 1)" disabled="@(response.PageNumber == response.TotalPages)">Next</button>
                    </li>
                </ul>
            </nav>
            <p>Total Accounts: @response.TotalCount</p>
        </div>
    }
}
else
{
    <p>No accounts found.</p>
}

@code {
    private List<AccountDto>? accounts;
    private AccountListResponse? response;
    private bool isLoading = true;
    private string? errorMessage;
    private int currentPage = 1;
    private int pageSize = 5;

    protected override async Task OnInitializedAsync()
    {
        await LoadAccounts();
    }

    private async Task LoadAccounts()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            response = await AccountService.GetAccountsAsync(currentPage, pageSize);
            accounts = response?.Accounts;
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load accounts: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadPage(int pageNumber)
    {
        currentPage = pageNumber;
        await LoadAccounts();
    }
}
